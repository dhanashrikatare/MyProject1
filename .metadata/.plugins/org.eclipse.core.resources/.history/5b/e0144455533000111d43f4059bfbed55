package com.activities.request;

import static io.restassured.RestAssured.*;
import static org.hamcrest.Matchers.*;

import java.util.UUID;

import org.testng.annotations.Test;

public class AuthorsPostValidReqSpec {
	
	
	static int randomNum = (int)(Math.random()*1000);
	 static String randomString = UUID.randomUUID().toString();
	
	
	 @Test
	public void verifyPostWithValidReqSpec() {
		given().
		body("{\r\n"
				+ "  \"id\": "+randomNum+",\r\n"
				+ "  \"idBook\": "+randomNum+",\r\n"
				+ "  \"firstName\":"+randomString+",\r\n"
				+ "  \"lastName\": "+randomString+"\r\n"
				+ "}").
		header("Content-Type","application/json").
		when().post("https://fakerestapi.azurewebsites.net/api/v1/Authors").
		then().log().all().statusCode(200).body("id", equalTo(randomNum))
		.body("title", equalTo(randomNum))
		.body("firstName", equalTo(randomString))
		.body("lastName", equalTo(randomString))
		
		;
		
		
	}


}
